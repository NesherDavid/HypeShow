# ── API KEYS & SECRETS ──────────────────────────────────────
.env
.env.local
.env.production
.env*.local
*.pem
secrets/
*secret*
*apikey*

# ── NODE / SERVER ───────────────────────────────────────────
node_modules/
dist/
.vercel/

# ── SYSTEM FILES ────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── LOGS ────────────────────────────────────────────────────
*.log
logs/

# ── PYTHON ──────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.venv/
venv/

# ── LARGE BINARY ASSETS (use Git LFS for these) ─────────────
