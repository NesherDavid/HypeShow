{
  "cleanUrls": true,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/", "destination": "/02_MARKETING_ASSETS/marketing-foundation/index.html" },
    { "source": "/live", "destination": "/dashboard/index.html" },
    { "source": "/dashboard_old", "destination": "/dashboard_old.html" }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/dashboard",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ]
}
